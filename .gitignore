# Gitignore for Task Management App

# --- General ---
# Operating System generated files
.DS_Store
Thumbs.db
ehthumbs.db
.Spotlight-V100
.Trashes
*.swp
*.swo
*.bak

# Logs and temporary files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor/IDE specific files
.vscode/                 # VS Code settings (uncomment if you want to ignore)
.idea/                   # IntelliJ/PHPStorm settings
*.sublime-project
*.sublime-workspace
*.code-workspace

# Environment variables
# Keep .env.example, but ignore actual .env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- Frontend (Next.js/React/TypeScript) ---
frontend/node_modules/
frontend/.next/                 # Next.js build output directory
frontend/out/                   # Next.js static export directory
frontend/dist/                  # Common build output directory
frontend/coverage/              # Test coverage reports
frontend/*.tsbuildinfo          # TypeScript build info files

# --- Backend (PHP) ---
backend/vendor/                 # Composer dependencies
backend/storage/*.log           # Application logs (e.g., Monolog)
backend/storage/framework/cache/*
backend/storage/framework/sessions/*
backend/storage/framework/views/*
backend/bootstrap/cache/*.php   # Framework cache files (e.g., generated routes, services)

# Backend specific uploads/generated files (uncomment if applicable)
# backend/public/uploads/       # Example: User-uploaded files, if not versioned
# backend/public/build/         # Example: Frontend assets built into backend public dir
```